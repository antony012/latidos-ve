# LatidosVE — Supabase: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# Usa anon key (legacy) o publishable key (nuevo panel de Supabase)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-o-publishable-key
# Alternativa al nombre anterior (mismo valor):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=tu-publishable-key
# Service role (solo servidor — nunca NEXT_PUBLIC). Gestión de códigos de encargados.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL pública de la app (PWA y redirects OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Consola secreta super admin (solo servidor — no uses NEXT_PUBLIC)
SUPER_ADMIN_EMAIL=tu-correo@gmail.com
SUPER_ADMIN_PASSWORD=cambia-esta-contraseña-temporal
SUPER_ADMIN_SESSION_SECRET=genera-un-secreto-largo-aleatorio
